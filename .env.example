# ─────────────────────────────────────────────────────────────────────────────
# zed2api — environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# Port exposed on the host (container always listens on 8000)
PORT=8000

# Directory on the host that contains accounts.json
# The container mounts this directory at /data and reads /data/accounts.json
# Example: ACCOUNTS_DIR=/home/user   (if accounts.json lives at /home/user/accounts.json)
ACCOUNTS_DIR=~

# API key for protecting the proxy endpoints (optional)
# When set, all /v1/* and /zed/* requests must include:
#   Authorization: Bearer <key>   OR   X-API-Key: <key>
# Leave blank for open access.
# API_KEY=your-secret-key-here

# HTTPS proxy for outbound requests to cloud.zed.dev (optional)
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
