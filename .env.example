# ─────────────────────────────────────────────────────────────────────────────
# zed2api — environment variables
# Copy this file to .env and fill in your values.
# .env is git-ignored; never commit it.
# ─────────────────────────────────────────────────────────────────────────────

# Port exposed on the host (container always listens on 8000)
PORT=8000

# Path to accounts.json on the host (contains Zed OAuth credentials)
# Default: ./accounts.json next to docker-compose.yml
ACCOUNTS_FILE=./accounts.json

# HTTPS proxy for outbound requests to cloud.zed.dev (optional)
# HTTPS_PROXY=http://127.0.0.1:7890
# ALL_PROXY=socks5://127.0.0.1:7890
